# ─────────────────────────────────────────────────────────────────────
# Frontend production environment for erp.alyarubi-group.com
# Copy to .env.production (or .env.local) on the server. Values are
# baked at build time, so re-build the Next.js app after changing them.
# ─────────────────────────────────────────────────────────────────────

# Public URL of the backend API. Without trailing slash.
# - If you reverse-proxy the API under the same host at /api, point it
#   here and add a corresponding Nginx location block.
# - If the backend has its own subdomain, use that instead.
NEXT_PUBLIC_API_BASE_URL=https://erp.alyarubi-group.com/api
