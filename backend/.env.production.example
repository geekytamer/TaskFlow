# ─────────────────────────────────────────────────────────────────────
# Backend production environment for erp.alyarubi-group.com
# Copy this file to .env and fill in the marked values before booting.
# ─────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=4005

# ── Database ────────────────────────────────────────────────────────
# Path to the SQLite file. Defaults to ./taskflow.db relative to CWD.
# Override only if you want it on a mounted volume.
# DB_PATH=/var/lib/taskflow/taskflow.db

# Set this to "false" so the demo seed data (placeholder users,
# fake projects, etc.) does NOT load on first boot. The bootstrap
# admin below is created instead.
SEED_ON_EMPTY=false

# Hard reset endpoint (POST /reset) — leave OFF in production.
ALLOW_SEED_RESET=false

# ── CORS ────────────────────────────────────────────────────────────
# Comma-separated list of origins that may call the API.
# Add any other domains your frontend serves from.
ALLOWED_ORIGINS=https://erp.alyarubi-group.com

# ── WhatsApp encryption (Green API tokens at rest) ──────────────────
# AES-256-GCM key for encrypting per-company API tokens.
# This value was generated with `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
# IF YOU LOSE THIS, ALL STORED WHATSAPP TOKENS BECOME UNREADABLE.
# Keep it in your password vault. Never commit a real value.
WHATSAPP_ENCRYPTION_KEY=4700c4d5a80fef34b1f12f99edc6d09d1ae1fa2f436da8d08bcdd73e6302653e

# ── Public base URL ─────────────────────────────────────────────────
# Used to construct the WhatsApp webhook URL when "Configure webhook"
# is clicked in Settings. Should point at the publicly-reachable
# backend (without trailing slash).
PUBLIC_BASE_URL=https://erp.alyarubi-group.com

# ── App (frontend) URL for PDF rendering ────────────────────────────
# The "Download PDF" button renders the public invoice page with a
# headless Chromium. Point this at the running FRONTEND (where
# /invoice/:id is served), without a trailing slash. Defaults to
# http://localhost:3000 for local dev. Requires Chromium in the backend
# environment (downloaded automatically with the `puppeteer` dependency).
APP_PUBLIC_URL=https://erp.alyarubi-group.com

# ── Bootstrap admin (used only on a fresh DB) ───────────────────────
# If no Admin user exists at startup, one is created from these.
# After first boot, log in, change the password, and remove these
# lines (they're then a no-op anyway).
ADMIN_EMAIL=admin@alyarubi-group.com
ADMIN_PASSWORD=Admin@IMiC0ITOBxQ
ADMIN_NAME=Administrator

# ── First company (created only if the DB has no companies) ─────────
COMPANY_NAME=Al Yarubi Group
COMPANY_WEBSITE=https://alyarubi-group.com
COMPANY_ADDRESS=

# ── Background sweeps ──────────────────────────────────────────────
# Overdue-invoice follow-up sweep interval, ms. Default 30 min.
# FOLLOWUP_SWEEP_INTERVAL_MS=1800000

# ── Green API host ─────────────────────────────────────────────────
# Default works for most accounts; override if Green API rents you
# a per-instance host.
# GREEN_API_HOST=https://api.green-api.com
